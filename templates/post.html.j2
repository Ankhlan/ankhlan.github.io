<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ title }} · {{ site_title }}</title>
  {% if summary %}<meta name="description" content="{{ summary }}">{% endif %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,400;0,600;1,400&family=Noto+Serif:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/tufte.css">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"
    onload="renderMathInElement(document.body, {delimiters:[
      {left:'$$',right:'$$',display:true},
      {left:'$',right:'$',display:false}
    ], throwOnError:false});"></script>

  <style>
    .tex-island { display:block; margin: 1.6em auto; max-width: 100%; height:auto; }
    figure.tex-figure { text-align:center; }
    figure.tex-figure .tex-island { margin: 0 auto 0.4em; }
  </style>
</head>
<body>
  <div class="site">

    <header class="site-header">
      <div class="site-title-block">
        <a href="/" class="site-title">{{ site_title }}</a>
        <div class="site-subtitle">{{ site_subtitle }}</div>
      </div>
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/about.html">About</a>
      </nav>
    </header>

    <main class="page">
      <article aria-labelledby="post-title">
        <h1 id="post-title">{{ title }}</h1>
        <p class="meta">
          {% if date %}<time datetime="{{ date }}">{{ date }}</time>{% endif %}
          {% if tags %}
            <span class="tags">
              {% for t in tags %}<span class="tag">{{ t }}</span>{% endfor %}
            </span>
          {% endif %}
        </p>

        {{ body | safe }}

        <footer class="post-footer" style="margin-top:2.5rem;">
          <p><a href="/">&larr; Back to index</a></p>
        </footer>
      </article>
    </main>

    <footer class="site-footer">
      <span>Static HTML. No tracking. Built with TeX islands.</span>
    </footer>
  </div>

  <script src="/assets/js/reader.js"></script>
</body>
</html>
