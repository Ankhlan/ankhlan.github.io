<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ title | default('About') }} · {{ site_title }}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,400;0,600;1,400&family=Noto+Serif:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/tufte.css">

  <style>
    .author-photo {
      float: right;
      width: 200px;
      height: auto;
      margin: 0 0 1rem 1.5rem;
      border-radius: 0.25rem;
      shape-outside: margin-box;
    }
    @media (max-width: 700px) {
      .author-photo {
        float: none;
        display: block;
        width: 100%;
        max-width: 240px;
        margin: 0 auto 1.2rem;
      }
    }
    article h1 { margin-bottom: 0.2rem; }
    article h1 + p { color: #6b6757; font-family: "Noto Sans", system-ui, sans-serif; font-size: 0.92rem; margin-top: 0; }
    article h2 { margin-top: 2rem; font-size: 1.05rem; text-transform: uppercase; letter-spacing: 0.06em; color: #4a4839; border-bottom: 1px solid #d6d2c2; padding-bottom: 0.25rem; }
    article h3 { margin-top: 1.4rem; font-size: 1rem; }
    article ul { padding-left: 1.2em; }
    article li { margin-bottom: 0.3em; }
  </style>
</head>
<body>
  <div class="site">

    <header class="site-header">
      <div class="site-title-block">
        <a href="/" class="site-title">{{ site_title }}</a>
        <div class="site-subtitle">{{ site_subtitle }}</div>
      </div>
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/about.html">About</a>
      </nav>
    </header>

    <main class="page">
      <article>
        {{ body | safe }}
      </article>
    </main>

    <footer class="site-footer">
      <span>Static HTML. No tracking. Built with TeX islands.</span>
    </footer>
  </div>

  <script src="/assets/js/reader.js"></script>
</body>
</html>
